# These are optional defaults only - both URLs can also be set/changed at
# runtime from the in-app Settings screen (stored in the browser's
# localStorage). Env vars just pre-fill them for a given deployment so you
# don't have to type them in by hand every time.

# LoginSystem's base URL - handles /api/auth, /api/organizations, /api/users
VITE_LOGIN_SYSTEM_URL="https://your-loginsystem.onrender.com"

# QuizSystem.Api's base URL - handles everything else (question groups,
# folders, questions, quizzes, admin/student views, answers)
VITE_QUIZ_API_URL="https://your-quizsystem-api.onrender.com"
